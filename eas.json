{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "sdk-54"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "sdnpk-54"
      }
    },
    "production": {
      "ios": {
        "image": "sdk-54"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-account.json",
        "track": "internal"
      }
    }
  }
}
